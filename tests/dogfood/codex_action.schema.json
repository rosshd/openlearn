{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "openLearn dogfood keyboard decision",
  "type": "object",
  "additionalProperties": false,
  "required": ["action", "text", "key", "reason", "commentary"],
  "properties": {
    "action": { "enum": ["submit_text", "press_key", "stop"] },
    "text": {
      "type": ["string", "null"],
      "minLength": 1,
      "maxLength": 1000,
      "pattern": "^[^\\u0000-\\u001F\\u007F]+$"
    },
    "key": {
      "enum": [
        "enter",
        "escape",
        "backspace",
        "up",
        "down",
        "left",
        "right",
        "ctrl_c",
        null
      ]
    },
    "reason": { "type": ["string", "null"], "minLength": 1, "maxLength": 240 },
    "commentary": { "type": ["string", "null"], "minLength": 1, "maxLength": 240 }
  }
}
